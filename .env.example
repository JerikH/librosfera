# ============================================================
# Librosfera - Variables de entorno (backend + docker-compose)
# Copiar este archivo como .env y rellenar los valores reales
# ============================================================

NODE_ENV=production
PORT=5000
DEBUG=false
ENABLE_CRON_JOBS=true

# MongoDB Atlas
MONGO_URI=mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority&appName=NombreApp

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_seguro
JWT_EXPIRE=30d

# Email (nodemailer)
EMAIL_USER=tu@email.com
EMAIL_PASSWORD=tu_app_password

# URLs públicas del proyecto
# BASE_URL  → dominio donde corre el backend (para links de uploads, Swagger, etc.)
# FRONT_URL → dominio donde corre el frontend (para links en emails y reset de password)
BASE_URL=https://tu-dominio.com
FRONT_URL=https://tu-dominio.com
